{
  "name": "Notepad Secure",
  "version": "1.0.0",
  "manifest_version": 2,
  "description": "Easy & Secure Offline Notepad",
  "homepage_url": "https://npsecure.cf/",
  "icons": {
    "16": "icons/36.png"
  },
  "default_locale": "en",
  "background": {
    "page": "src/bg/background.html",
    "persistent": true
  },
  "browser_action": {
    "default_icon": "icons/36.png",
    "default_title": "browser action demo",
    "default_popup": "src/browser_action/browser_action.html"
  }
}